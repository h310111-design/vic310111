{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "links": { "type": "array" },
        "interests": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "Post": {
      "title": "Post",
      "description": "A photo post with caption and metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "imageUrl", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "A short-lived photo story",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "imageUrl", "expiresAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct message between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Main feed posts"
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Temporary stories"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages within a chat"
    }
  }
}
